# =============================================================================
# KANKI STREET — Variables de entorno
# Copiar como .env.local y completar con valores reales
# NUNCA commitear .env.local (está en .gitignore)
# Fuente de verdad en producción: Vercel Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE
# Obtener en: supabase.com → proyecto → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Storage bucket para comprobantes y fotos de productos
SUPABASE_STORAGE_BUCKET=kanki-assets

# -----------------------------------------------------------------------------
# IA — CHATBOTS (fallback chain: Groq → Gemini → DeepSeek)
# Reutilizar keys existentes de InfoPet si están en Amplify
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
COHERE_API_KEY=...

# -----------------------------------------------------------------------------
# GOOGLE (Analytics + GTM + reCAPTCHA + Gmail)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# reCAPTCHA v3 — proteger checkout contra bots
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Le...
RECAPTCHA_SECRET_KEY=6Le...

# Gmail API — envío de emails transaccionales (smconnection.cl workspace)
# Obtener en: console.cloud.google.com → OAuth 2.0 → Credentials
GMAIL_CLIENT_ID=XXXXXXXXXXXX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...
GMAIL_FROM_EMAIL=hola@kanki.cl

# -----------------------------------------------------------------------------
# WHATSAPP
# Número sin espacios ni +, con código de país
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WA_NUMBER=56912345678

# -----------------------------------------------------------------------------
# MERCADOLIBRE (Fase 2 — comentado hasta implementación)
# Crear app en: developers.mercadolibre.cl
# -----------------------------------------------------------------------------
# MELI_CLIENT_ID=
# MELI_CLIENT_SECRET=
# MELI_REDIRECT_URI=https://kanki.cl/api/webhooks/mercadolibre/callback
# MELI_USER_ID=

# -----------------------------------------------------------------------------
# SHIPIT (Fase 2 — integración de couriers)
# https://developers.shipit.cl
# -----------------------------------------------------------------------------
# SHIPIT_API_KEY=
# SHIPIT_API_SECRET=
# SHIPIT_SANDBOX=true

# -----------------------------------------------------------------------------
# WEBPAY / TRANSBANK (Fase 2)
# https://www.transbankdevelopers.cl
# -----------------------------------------------------------------------------
# WEBPAY_COMMERCE_CODE=
# WEBPAY_API_KEY=
# WEBPAY_ENV=integration

# -----------------------------------------------------------------------------
# MERCADOPAGO (Fase 2 — alternativa a Webpay)
# https://www.mercadopago.cl/developers
# -----------------------------------------------------------------------------
# MP_ACCESS_TOKEN=
# MP_PUBLIC_KEY=
# NEXT_PUBLIC_MP_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# SEGURIDAD
# -----------------------------------------------------------------------------
# Secret para firmar webhooks entrantes
WEBHOOK_SECRET=kanki_webhook_secret_muy_largo_y_random

# Dominio canónico (para CORS y cookies)
NEXT_PUBLIC_APP_URL=https://kanki.cl

# Auth admin: lista de emails autorizados para /admin (separados por coma)
ADMIN_EMAILS=guillermo@smconnection.cl,admin@kanki.cl

# -----------------------------------------------------------------------------
# POSTHOG (Fase 2 — analytics de producto)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
